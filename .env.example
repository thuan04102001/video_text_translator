# Optional: required only when the tool should exchange a short-lived
# Meta User Access Token for a long-lived User Access Token.
META_APP_ID=
META_APP_SECRET=

# Graph API and background token monitor settings.
META_GRAPH_VERSION=v20.0
META_TOKEN_MONITOR_INTERVAL_SECONDS=60

# Auto Reup runtime. Time windows are interpreted in this timezone.
AUTO_REUP_TIMEZONE=Asia/Bangkok
AUTO_REUP_RUNTIME_INTERVAL_SECONDS=5
AUTO_REUP_PREPARE_WORKERS=1
